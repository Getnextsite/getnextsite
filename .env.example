# Public site URL (used for canonical URLs, sitemap, OG tags, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://getnextsite.com

# Formspree endpoint (optional — enables real form delivery on the static build)
# Get one at https://formspree.io — free tier, 50 submissions/mo.
# Without this the forms simulate a success response.
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/abcxyz123
